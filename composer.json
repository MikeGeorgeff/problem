{
  "name": "georgeff/problem",
  "description": "Translate exceptions to structured domain problems with a fluent builder and logger.",
  "type": "library",
  "authors": [
    {
      "name": "Mike Georgeff",
      "email": "mike@georgeff.co",
      "role": "Author"
    }
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "squizlabs/php_codesniffer": "^3.11"
  },
  "autoload": {
    "psr-4": {
      "Georgeff\\Problem\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Georgeff\\Problem\\Test\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": ["vendor/bin/phpunit"],
    "analyze": ["vendor/bin/phpstan"],
    "phpcs": ["vendor/bin/phpcs"]
  }
}
